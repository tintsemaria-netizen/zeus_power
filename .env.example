# Zeus Power research app — example environment (NO SECRETS). Copy to .env and fill in.

# --- Analyzer MVP (current phase) uses none of the below; provided for later phases. ---

# Authorized endpoint (do not point at anything you are not authorized to test)
ZEUS_ENDPOINT=https://betman-demo.head.kendoo.pro/betman-demo/gs/zeus_power/desktop/611495f06ee84c71b12dae70001923ec/demo/

# Demo token is encrypted at rest and never returned to the frontend. Set the real value in .env.
ZEUS_DEMO_TOKEN=

# Safety limits (conservative defaults)
MAX_CONCURRENCY=1
REQUEST_DELAY_MS=250
REQUEST_JITTER_MS=150
STOP_MAX_PAID_SPINS=1000
STOP_MAX_WAGER_MINOR=0
STOP_ERROR_THRESHOLD=5

# Secrets encryption key (32-byte base64) — generate locally, never commit
SECRETS_KEY=

# Phase 6+ services
POSTGRES_URL=postgres://zeus:zeus@localhost:5432/zeus
CLICKHOUSE_URL=http://localhost:8123
